  <Code>Public Function BlankZero(ByVal Value As Decimal)
    if Value = 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankPos(ByVal Value As Decimal)
    if Value &gt; 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankZeroAndPos(ByVal Value As Decimal)
    if Value &gt;= 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankNeg(ByVal Value As Decimal)
    if Value &lt; 0 then
        Return ""
    end if
    Return Value
End Function

Public Function BlankNegAndZero(ByVal Value As Decimal)
    if Value &lt;= 0 then
        Return ""
    end if
    Return Value
End Function

Dim currentInvoice As String
Dim currentDate As String

Public Function SetInvoice(ByVal inv As String) As String
    currentInvoice = inv
    Return inv
End Function

Public Function GetInvoice() As String
    Return currentInvoice
End Function

Public Function SetDate(ByVal dt As String) As String
    currentDate = dt
    Return dt
End Function

Public Function GetDate() As String
    Return currentDate
End Function</Code>
